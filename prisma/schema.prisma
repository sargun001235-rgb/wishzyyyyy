generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------
// Product catalog (mirrored from Shopify via webhooks)
// -----------------------------
model Product {
  id             String    @id @default(cuid())
  shopifyId      String    @unique // gid://shopify/Product/xxxx
  handle         String    @unique
  title          String
  descriptionHtml String   @default("")
  status         String    @default("active") // active | draft | archived
  vendor         String?
  productType    String?
  tags           String[]  @default([])
  priceMin       Decimal   @db.Decimal(10, 2)
  priceMax       Decimal   @db.Decimal(10, 2)
  currencyCode   String    @default("USD")
  featuredImage  String?
  variants       Variant[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
  @@index([handle])
}

model Variant {
  id          String   @id @default(cuid())
  shopifyId   String   @unique // gid://shopify/ProductVariant/xxxx
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  title       String
  sku         String?
  price       Decimal  @db.Decimal(10, 2)
  compareAtPrice Decimal? @db.Decimal(10, 2)
  inventoryQty Int      @default(0)
  imageUrl    String?
  options     Json      @default("{}")
  cartLines   CartLine[]

  @@index([productId])
}

// -----------------------------
// Persistent cart (survives hard refresh via HTTP-only session cookie)
// -----------------------------
model Cart {
  id          String     @id @default(cuid())
  sessionId   String     @unique // value stored in the HTTP-only cookie
  lines       CartLine[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  expiresAt   DateTime
}

model CartLine {
  id         String   @id @default(cuid())
  cartId     String
  cart       Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variantId  String
  variant    Variant  @relation(fields: [variantId], references: [id])
  quantity   Int      @default(1)
  addedAt    DateTime @default(now())

  @@unique([cartId, variantId])
}

// -----------------------------
// Orders (COD orders pushed to Shopify Admin API)
// -----------------------------
model Order {
  id                String      @id @default(cuid())
  shopifyOrderId    String?     @unique // populated once pushed successfully
  status            OrderStatus @default(PENDING_COD)
  customerName      String
  customerEmail     String
  customerPhone     String
  shippingAddress   Json
  lineItems         Json        // snapshot of { variantId, title, quantity, price }
  subtotal          Decimal     @db.Decimal(10, 2)
  total             Decimal     @db.Decimal(10, 2)
  currencyCode      String      @default("USD")
  paymentMethod     String      @default("Cash on Delivery")
  shopifyPushError  String?
  shopifyPushedAt   DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([status])
  @@index([createdAt])
}

enum OrderStatus {
  PENDING_COD
  SYNCED_TO_SHOPIFY
  SYNC_FAILED
  FULFILLED
  CANCELLED
}

// -----------------------------
// Webhook ingestion log (for admin dashboard sync visibility)
// -----------------------------
model WebhookLog {
  id           String   @id @default(cuid())
  topic        String   // products/create | products/update | products/delete
  shopifyId    String?
  payloadHash  String   // for idempotency de-dupe
  status       String   @default("received") // received | processed | failed
  errorMessage String?
  receivedAt   DateTime @default(now())
  processedAt  DateTime?

  @@unique([payloadHash])
  @@index([topic])
  @@index([receivedAt])
}
